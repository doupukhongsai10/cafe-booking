# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Replace with your actual connection string in .env
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cafe_booking?schema=public"

# Authentication Secrets
# Generate a secure string for JWT signing
JWT_SECRET="your_super_secret_jwt_signature_key_change_me_in_production"

# Cloudinary Integration (For Cafe Onboarding Photos)
# Copy the connection string from your Cloudinary Dashboard
CLOUDINARY_URL="cloudinary://my_api_key:my_api_secret@my_cloud_name"

# Client Configuration (Only used by frontend build/development)
VITE_API_URL="http://localhost:5000"
